# --- 本地：直连本机 Rust serve ---
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000

# --- 生产（Vercel HTTPS）二选一 ---

# A) 后端已配置 HTTPS 域名（推荐长期方案）
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com
# 后端 PAA_CORS_ORIGINS 需包含 https://你的前端.vercel.app

# B) 后端只有 http://VPS_IP:3000 → 用同源代理，避免浏览器 Mixed Content 拦截
# NEXT_PUBLIC_API_BASE_URL=/api/backend
# ANALYZER_BACKEND_URL=http://VPS_IP:3000
# （ANALYZER_BACKEND_URL 仅服务端可见，不要加 NEXT_PUBLIC_）

# 可选：/docs 页面「外部文档」链接（Mintlify 文档站等）
# NEXT_PUBLIC_DOCS_URL=https://your-docs.example.com

# 可选：页脚外链（未设置的项不显示）。文档：优先 FOOTER_DOCS，否则沿用 NEXT_PUBLIC_DOCS_URL。
# NEXT_PUBLIC_FOOTER_X_URL=https://x.com/your_handle
# NEXT_PUBLIC_FOOTER_DISCORD_URL=https://discord.gg/...
# NEXT_PUBLIC_FOOTER_TELEGRAM_URL=https://t.me/...
# NEXT_PUBLIC_FOOTER_MEDIUM_URL=https://medium.com/@...
# NEXT_PUBLIC_FOOTER_DOCS_URL=https://your-docs.example.com
# NEXT_PUBLIC_FOOTER_GITHUB_URL=https://github.com/org/repo

# --- Polymarket 官方榜单（默认浏览器直连 data-api；无需配置）---
# 可选：覆盖 leaderboard base URL（自建反代等）
# NEXT_PUBLIC_POLYMARKET_LEADERBOARD_URL=https://data-api.polymarket.com/v1/leaderboard
# 若浏览器 CORS 拦截官方域名，改为走 Next 服务端代理：
# NEXT_PUBLIC_POLYMARKET_LEADERBOARD_SERVER_PROXY=1
# 代理路由上游（仅服务端读）：POLYMARKET_DATA_API_ORIGIN、HTTPS_PROXY 等
# POLYMARKET_DATA_API_ORIGIN=https://data-api.polymarket.com
# HTTPS_PROXY=http://127.0.0.1:7890

# --- Gamma 公开资料（默认浏览器直连 gamma-api；无需配置）---
# NEXT_PUBLIC_POLYMARKET_GAMMA_ORIGIN=https://gamma-api.polymarket.com
# 若浏览器 CORS 拦截，走本站代理：
# NEXT_PUBLIC_POLYMARKET_GAMMA_SERVER_PROXY=1
# 代理路由上游（仅服务端）：POLYMARKET_GAMMA_ORIGIN=https://gamma-api.polymarket.com

# --- 官网同款 user-stats / user-pnl（账户页区块，默认浏览器直连）---
# NEXT_PUBLIC_POLYMARKET_USER_STATS_URL=https://data-api.polymarket.com/v1/user-stats
# NEXT_PUBLIC_POLYMARKET_USER_PNL_URL=https://user-pnl-api.polymarket.com/user-pnl
